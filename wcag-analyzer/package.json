{
  "name": "wcag-analyzer",
  "version": "1.0.0",
  "description": "WCAG 2.1 Compliance Testing Tool for React/TypeScript Components",
  "main": "dist/index.js",
  "bin": {
    "wcag-analyzer": "./bin/wcag-analyzer.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:property": "jest tests/property",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "wcag",
    "accessibility",
    "a11y",
    "react",
    "typescript",
    "testing",
    "compliance"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/types": "^7.23.0",
    "commander": "^11.1.0",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.4",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "fast-check": "^3.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
