pipeline {
    agent any
    
    tools {
        nodejs 'Node20'
    }
    
    environment {
        SONAR_SCANNER_HOME = tool 'SonarScanner'
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo 'Récupération du code source...'
                checkout scm
            }
        }
        
        stage('Install Dependencies') {
            steps {
                dir('backend') {
                    echo 'Installation des dépendances...'
                    bat 'npm ci'
                }
            }
        }
        
        stage('Lint') {
            steps {
                dir('backend') {
                    echo 'Vérification du code avec ESLint...'
                    bat 'npm run lint'
                }
            }
        }
        
        stage('Build') {
            steps {
                dir('backend') {
                    echo 'Construction du projet...'
                    bat 'npm run build'
                }
            }
        }
        
        stage('Test') {
            steps {
                dir('backend') {
                    echo 'Exécution des tests avec couverture...'
                    bat 'npm run test:ci'
                }
            }
            post {
                always {
                    dir('backend') {
                        // Publication des résultats de tests
                        publishTestResults testResultsPattern: 'coverage/junit.xml'
                        
                        // Publication de la couverture de code
                        publishCoverage adapters: [
                            istanbulCoberturaAdapter('coverage/cobertura-coverage.xml')
                        ], sourceFileResolver: sourceFiles('STORE_LAST_BUILD')
                    }
                }
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                dir('backend') {
                    withSonarQubeEnv('SonarQubeServer') {
                        bat """
                            ${SONAR_SCANNER_HOME}/bin/sonar-scanner ^
                            -Dsonar.projectKey=backend-hr-system ^
                            -Dsonar.projectName="Backend HR System" ^
                            -Dsonar.projectVersion=1.0 ^
                            -Dsonar.sources=src ^
                            -Dsonar.tests=src ^
                            -Dsonar.test.inclusions=**/*.spec.ts ^
                            -Dsonar.exclusions=**/*.spec.ts,node_modules/**,dist/** ^
                            -Dsonar.typescript.lcov.reportPaths=coverage/lcov.info ^
                            -Dsonar.testExecutionReportPaths=coverage/test-report.xml
                        """
                    }
                }
            }
        }
        
        stage('Quality Gate') {
            steps {
                timeout(time: 1, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }
    
    post {
        always {
            echo 'Pipeline terminé'
        }
        success {
            echo '✅ Pipeline réussi ! Tests passés et analyse SonarQube terminée.'
        }
        failure {
            echo '❌ Pipeline échoué. Vérifiez les logs pour plus de détails.'
        }
        cleanup {
            cleanWs()
        }
    }
}